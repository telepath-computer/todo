{
  "name": "@telepath-computer/todo",
  "version": "0.2.0",
  "description": "GTD-style task and project CLI over structured markdown files. Designed for LLM agents to mutate without grepping freeform notes.",
  "type": "module",
  "bin": {
    "todo": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs/spec.md",
    "docs/cli.md",
    "README.md"
  ],
  "keywords": [
    "cli",
    "gtd",
    "todo",
    "tasks",
    "markdown",
    "obsidian",
    "agents"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "pretest": "npm run build",
    "test": "node --import tsx --test tests/*.test.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "chrono-node": "^2.9.0",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
